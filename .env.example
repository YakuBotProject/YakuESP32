APP_ENV=production
COOKIE_SECURE=true
ALLOWED_ORIGINS=https://app.example.com

DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=yaku
DB_USER=yaku_user
DB_PASSWORD=change-me

JWT_SECRET_KEY=change-me-minimum-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BFF_JWT_SECRET=change-me-same-value-as-frontend-minimum-32-characters

MQTT_HOST=your-mqtt-host
MQTT_PORT=8883
MQTT_TLS_ENABLED=true
MQTT_TLS_CA_CERT=
MQTT_USERNAME=your-mqtt-user
MQTT_PASSWORD=change-me
MQTT_TOPIC_RIEGO_DATOS=yaku/riego/datos
MQTT_TOPIC_CONTROL_CMD=yaku/riego/comando
MQTT_TOPIC_CONTROL_AGUA=yaku/tanque/datos

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

FIRMWARE_STORAGE_PATH=firmware_store
ML_IRRIGATION_COOLDOWN_MINUTES=60
